[Unit]
Description=Gastro Setup Hotspot + Web UI (fallback)
After=network.target NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/gastro-system
ExecStart=/bin/bash -lc '/opt/gastro-system/deploy/gastro-setup-run.sh'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

