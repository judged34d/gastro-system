# Copy to /opt/gastro-system/deploy/gastro-telegram-bot.env and fill values.
# IMPORTANT: If you use the SAME token as SmartCalendar, only one polling bot can run at a time.
# Recommended: create a dedicated bot token for Gastro.

GASTRO_TELEGRAM_TOKEN=PUT_TELEGRAM_BOT_TOKEN_HERE

# Optional: comma-separated chat ids allowed to use bot commands.
# Example: GASTRO_TELEGRAM_CHAT_IDS=123456789,987654321
GASTRO_TELEGRAM_CHAT_IDS=

# Optional poll tuning.
GASTRO_TELEGRAM_POLL_TIMEOUT=25
GASTRO_TELEGRAM_SLEEP_SEC=1.5
